# ~/.bashrc.local
#
# Machine-local shell overrides. This file is sourced by .bashrc if it exists.
# It is intentionally not tracked — copy this to ~/.bashrc.local and customise.
#
# Examples:
#
#   # Machine-specific PATH additions
#   export PATH="$HOME/.local/share/mise/bin:$PATH"
#
#   # Work-specific env vars
#   export KUBECONFIG="$HOME/.kube/work-cluster.yaml"
#
#   # Override an alias from .bash_aliases
#   alias k='kubecolor'
