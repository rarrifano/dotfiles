{
  "lastChangelogVersion": "0.80.2",
  "theme": "gruvbox",
  "defaultProvider": "ollama",
  "defaultModel": "qwen2.5-coder:7b-instruct",
  "extensions": [
    "./extensions/hide-cursor.ts",
    "./extensions/git-checkpoint.ts",
    "./extensions/taskwarrior.ts",
    "./extensions/ollama.ts"
  ],
  "packages": [
    "npm:pi-web-access"
  ],
  "editorPaddingX": 1,
  "hideThinkingBlock": true,
  "collapseChangelog": true,
  "quietStartup": true,
  "enableInstallTelemetry": false,
  "defaultProjectTrust": "ask",
  "treeFilterMode": "no-tools",
  "defaultThinkingLevel": "minimal",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 24000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000
  },
  "steeringMode": "one-at-a-time",
  "followUpMode": "one-at-a-time",
  "shellCommandPrefix": "source ~/.bashrc 2>/dev/null || true;",
  "enabledModels": [
    "claude-sonnet*",
    "claude-haiku*"
  ],
  "showHardwareCursor": true
}