{
  "lastChangelogVersion": "0.81.1",
  "theme": "gruvbox",
  "defaultProvider": "github-copilot",
  "defaultModel": "claude-sonnet-4.6",
  "extensions": [
    "./extensions/hide-cursor.ts",
    "./extensions/taskwarrior.ts",
    "./extensions/rewind-footer.ts"
  ],
  "packages": [
    "npm:pi-web-access",
    "npm:pi-rewind"
  ],
  "editorPaddingX": 1,
  "hideThinkingBlock": false,
  "collapseChangelog": true,
  "quietStartup": true,
  "enableInstallTelemetry": false,
  "defaultProjectTrust": "ask",
  "treeFilterMode": "no-tools",
  "defaultThinkingLevel": "off",
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 24000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000
  },
  "steeringMode": "one-at-a-time",
  "followUpMode": "one-at-a-time",
  "shellCommandPrefix": "source ~/.bashrc 2>/dev/null || true;",
  "enabledModels": [
    "claude-sonnet*",
    "claude-haiku*"
  ],
  "showHardwareCursor": true,
  "warnings": {
    "anthropicExtraUsage": true
  },
  "doubleEscapeAction": "tree"
}