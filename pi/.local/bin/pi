#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "${SOURCE}" ]; do
  DIR="$(cd -P "$(dirname "${SOURCE}")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "${SOURCE}")"
  [[ "${SOURCE}" != /* ]] && SOURCE="${DIR}/${SOURCE}"
done
SCRIPT_DIR="$(cd -P "$(dirname "${SOURCE}")" >/dev/null 2>&1 && pwd)"
PI_SANDBOX="${SCRIPT_DIR}/../../.config/pi-sandbox"

PROJECT_NAME="$(basename "$(pwd)")"

TTY_FLAG=""
[ -t 0 ] && TTY_FLAG="-t"

docker run -i ${TTY_FLAG} --rm \
  -v "$(pwd)":"/${PROJECT_NAME}" \
  -v "$PI_SANDBOX":/root/.pi \
  -v pi-npm-global:/root/.npm-global \
  -w "/${PROJECT_NAME}" \
  node:lts \
  bash -lc '
    export NPM_CONFIG_PREFIX=/root/.npm-global
    export PATH="$NPM_CONFIG_PREFIX/bin:$PATH"

    if ! command -v pi >/dev/null 2>&1; then
      npm install -g --loglevel=error --no-audit --no-fund --no-update-notifier @earendil-works/pi-coding-agent >/dev/null
    fi

    exec pi "$@"
  ' bash "$@"
