#!/usr/bin/env bash
set -euo pipefail

IMAGE="${PI_IMAGE:-pi-agent:latest}"
VERSION="${1:-}"

if [[ -z "${VERSION}" ]]; then
    echo "==> Fetching latest pi version..."
    VERSION="$(curl -fsSL https://registry.npmjs.org/@earendil-works/pi-coding-agent/latest | grep -o '"version":"[^"]*"' | cut -d'"' -f4)"
    echo "==> Latest: ${VERSION}"
fi

# Build context: inject host CA certs if present
BUILD_CTX="$(mktemp -d)"
trap 'rm -rf "${BUILD_CTX}"' EXIT

mkdir -p "${BUILD_CTX}/ca-certs"
if compgen -G "/usr/local/share/ca-certificates/*.crt" > /dev/null 2>&1; then
    cp /usr/local/share/ca-certificates/*.crt "${BUILD_CTX}/ca-certs/"
    echo "==> Bundling $(ls "${BUILD_CTX}/ca-certs/" | wc -l) host CA cert(s) into image..."
else
    echo "==> No host CA certs found, skipping (image will use distro defaults)"
fi

echo "==> Building ${IMAGE} with pi@${VERSION}..."
cat > "${BUILD_CTX}/Containerfile" <<'CONTAINERFILE'
FROM node:24-bookworm-slim

# System dependencies
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        # clipboard support
        xclip \
        wl-clipboard \
        # shell essentials
        bash \
        curl \
        ca-certificates \
        git \
        unzip \
        jq \
        # editor
        vim \
        # devops
        gnupg \
        taskwarrior \
        # gh CLI dep (added via keyring below)
        apt-transport-https \
    && rm -rf /var/lib/apt/lists/*

# Host CA certificates
COPY ca-certs/ /usr/local/share/ca-certificates/
RUN if [ -n "$(ls /usr/local/share/ca-certificates/*.crt 2>/dev/null)" ]; then \
        update-ca-certificates; \
    fi

# gh CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        -o /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=amd64 signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update -qq && \
    apt-get install -y --no-install-recommends gh && \
    rm -rf /var/lib/apt/lists/*

# yq
ARG YQ_VERSION=v4.44.3
RUN curl -fsSL "https://github.com/mikefarah/yq/releases/download/${YQ_VERSION}/yq_linux_amd64" \
        -o /usr/local/bin/yq && \
    chmod +x /usr/local/bin/yq

# kubectl
RUN curl -fsSL "https://dl.k8s.io/release/$(curl -fsSL https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" \
        -o /usr/local/bin/kubectl && \
    chmod +x /usr/local/bin/kubectl

# helm
RUN curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

# terraform
ARG TERRAFORM_VERSION=1.9.8
RUN curl -fsSL "https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_amd64.zip" \
        -o /tmp/terraform.zip && \
    unzip -q /tmp/terraform.zip -d /usr/local/bin && \
    rm /tmp/terraform.zip

# AWS CLI
RUN curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" \
        -o /tmp/awscliv2.zip && \
    unzip -q /tmp/awscliv2.zip -d /tmp && \
    /tmp/aws/install && \
    rm -rf /tmp/aws /tmp/awscliv2.zip

# pi
ARG PI_VERSION=0.0.0-unset
RUN npm install -g --ignore-scripts \
        "@earendil-works/pi-coding-agent@${PI_VERSION}" && \
    npm cache clean --force

# Runtime
ENV NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt
WORKDIR /workspace
ENTRYPOINT ["pi"]
CONTAINERFILE

podman build \
    --build-arg "PI_VERSION=${VERSION}" \
    -t "${IMAGE}" \
    -f "${BUILD_CTX}/Containerfile" \
    "${BUILD_CTX}"

echo "==> Done! ${IMAGE} is ready (pi@${VERSION})"
