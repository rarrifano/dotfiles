#!/usr/bin/env bash
set -euo pipefail

IMAGE="${PI_IMAGE:-pi-agent:latest}"
VERSION="${1:-}"

if [[ -z "${VERSION}" ]]; then
    echo "==> Fetching latest pi version..."
    VERSION="$(curl -fsSL https://registry.npmjs.org/@earendil-works/pi-coding-agent/latest | grep -o '"version":"[^"]*"' | cut -d'"' -f4)"
    echo "==> Latest: ${VERSION}"
fi

echo "==> Building ${IMAGE} with pi@${VERSION}..."
podman build \
    --build-arg "PI_VERSION=${VERSION}" \
    -t "${IMAGE}" \
    -f - <<'CONTAINERFILE'
FROM node:24-bookworm-slim

# ── System dependencies ────────────────────────────────────────────────────────
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        # clipboard support
        xclip \
        wl-clipboard \
        # shell essentials
        bash \
        curl \
        ca-certificates \
        git \
        unzip \
        jq \
        # devops
        gnupg \
    && rm -rf /var/lib/apt/lists/*

# ── yq ────────────────────────────────────────────────────────────────────────
ARG YQ_VERSION=v4.44.3
RUN curl -fsSL "https://github.com/mikefarah/yq/releases/download/${YQ_VERSION}/yq_linux_amd64" \
        -o /usr/local/bin/yq && \
    chmod +x /usr/local/bin/yq

# ── kubectl ───────────────────────────────────────────────────────────────────
RUN curl -fsSL "https://dl.k8s.io/release/$(curl -fsSL https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" \
        -o /usr/local/bin/kubectl && \
    chmod +x /usr/local/bin/kubectl

# ── helm ──────────────────────────────────────────────────────────────────────
RUN curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

# ── terraform ─────────────────────────────────────────────────────────────────
ARG TERRAFORM_VERSION=1.9.8
RUN curl -fsSL "https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_amd64.zip" \
        -o /tmp/terraform.zip && \
    unzip -q /tmp/terraform.zip -d /usr/local/bin && \
    rm /tmp/terraform.zip

# ── AWS CLI ───────────────────────────────────────────────────────────────────
RUN curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" \
        -o /tmp/awscliv2.zip && \
    unzip -q /tmp/awscliv2.zip -d /tmp && \
    /tmp/aws/install && \
    rm -rf /tmp/aws /tmp/awscliv2.zip

# ── pi ────────────────────────────────────────────────────────────────────────
ARG PI_VERSION=0.79.9
RUN npm install -g --ignore-scripts \
        "@earendil-works/pi-coding-agent@${PI_VERSION}" && \
    npm cache clean --force

# ── Runtime ───────────────────────────────────────────────────────────────────
WORKDIR /workspace
ENTRYPOINT ["pi"]
CONTAINERFILE

echo "==> Done! ${IMAGE} is ready (pi@${VERSION})"
