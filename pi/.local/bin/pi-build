#!/usr/bin/env bash
set -euo pipefail

IMAGE="${PI_IMAGE:-pi-agent:latest}"
VERSION="${1:-}"

if [[ -z "${VERSION}" ]]; then
    echo "==> Fetching latest pi version..."
    VERSION="$(curl -fsSL https://registry.npmjs.org/@earendil-works/pi-coding-agent/latest | grep -o '"version":"[^"]*"' | cut -d'"' -f4)"
    echo "==> Latest: ${VERSION}"
fi

# Build context: inject host CA certs if present
BUILD_CTX="$(mktemp -d)"
trap 'rm -rf "${BUILD_CTX}"' EXIT

mkdir -p "${BUILD_CTX}/ca-certs"
if compgen -G "/usr/local/share/ca-certificates/*.crt" > /dev/null 2>&1; then
    cp /usr/local/share/ca-certificates/*.crt "${BUILD_CTX}/ca-certs/"
    echo "==> Bundling $(ls "${BUILD_CTX}/ca-certs/" | wc -l) host CA cert(s) into image..."
else
    echo "==> No host CA certs found, skipping (image will use distro defaults)"
fi

echo "==> Building ${IMAGE} with pi@${VERSION}..."
cat > "${BUILD_CTX}/Containerfile" <<'CONTAINERFILE'
FROM node:24-bookworm-slim

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# system deps — only what mise cannot provide
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        git \
        unzip \
        gpg \
        make \
        openssh-client \
        python3 \
    && rm -rf /var/lib/apt/lists/*

# host CA certificates
COPY ca-certs/ /usr/local/share/ca-certificates/
RUN if [ -n "$(ls /usr/local/share/ca-certificates/*.crt 2>/dev/null)" ]; then \
        update-ca-certificates; \
    fi

# mise
ENV MISE_DATA_DIR="/mise" \
    MISE_CACHE_DIR="/mise/cache" \
    MISE_INSTALL_PATH="/usr/local/bin/mise"
ENV PATH="/mise/shims:$PATH"
RUN curl -fsSL https://mise.run | sh

# core devops tools baked globally
RUN MISE_CONFIG_DIR=/mise mise use --global --jobs 8 \
        jq \
        yq \
        gh \
        ripgrep \
        fd \
        kubectl \
        helm \
        terraform && \
    mise reshim && \
    rm -rf /mise/cache

# pi
ARG PI_VERSION=0.0.0-unset
RUN npm install -g --ignore-scripts \
        "@earendil-works/pi-coding-agent@${PI_VERSION}" && \
    npm cache clean --force

# runtime
ENV NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt
WORKDIR /workspace
ENTRYPOINT ["pi"]
CONTAINERFILE

podman build \
    --format docker \
    --build-arg "PI_VERSION=${VERSION}" \
    -t "${IMAGE}" \
    -f "${BUILD_CTX}/Containerfile" \
    "${BUILD_CTX}"

echo "==> Done! ${IMAGE} is ready (pi@${VERSION})"
