#!/usr/bin/env bash
set -euo pipefail

CONTAINER_NAME="ollama-webui"
WEBUI_IMAGE="${WEBUI_IMAGE:-ghcr.io/open-webui/open-webui:main}"
WEBUI_PORT="${WEBUI_PORT:-3000}"
WEBUI_VOLUME="${WEBUI_VOLUME:-open-webui}"
OLLAMA_PORT="${OLLAMA_PORT:-11434}"

# Check if already running
if podman ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
    echo "[ollama-webui] already running — http://localhost:${WEBUI_PORT}" >&2
    exit 0
fi

# Remove stopped container if it exists
if podman ps -a --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}$"; then
    echo "[ollama-webui] removing stopped container..." >&2
    podman rm "${CONTAINER_NAME}" >/dev/null
fi

# Ensure Ollama is running
if ! podman ps --format '{{.Names}}' | grep -q '^ollama$'; then
    echo "[ollama-webui] warn: ollama container is not running — start it with: ollama-run" >&2
    echo "[ollama-webui] continuing anyway, WebUI will retry the connection..." >&2
fi

echo "[ollama-webui] starting Open WebUI on port ${WEBUI_PORT}..." >&2

podman run -d \
    --name "${CONTAINER_NAME}" \
    -p "${WEBUI_PORT}:8080" \
    --add-host=host.containers.internal:host-gateway \
    -e "OLLAMA_BASE_URL=http://host.containers.internal:${OLLAMA_PORT}" \
    -v "${WEBUI_VOLUME}:/app/backend/data" \
    "${WEBUI_IMAGE}"

echo "[ollama-webui] ready — http://localhost:${WEBUI_PORT}" >&2
