{
  "$schema": "https://opencode.ai/config.json",

  // -- Model --
  "model": "github-copilot/claude-sonnet-4",
  "enabled_providers": ["github-copilot"],

  // -- Identity --
  "username": "rarrifano",
  "share": "manual",
  "autoupdate": true,
  "snapshot": true,

  // -- Compaction --
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000,
  },

  // -- Watcher --
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      "coverage/**",
      "vendor/**",
      "__pycache__/**",
      ".venv/**",
      ".terraform/**",
      "*.tfstate",
      "*.tfstate.backup",
      ".terragrunt-cache/**",
    ],
  },

  // -- Permissions --
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "rm -r *": "ask",
      "git push --force*": "deny",
      "git push * --force*": "deny",
      "git reset --hard*": "ask",
      "git clean*": "ask",
      "sudo *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "curl * | bash*": "deny",
      "curl * | sh*": "deny",
      "wget * | bash*": "deny",
      "terraform destroy*": "ask",
      "tofu destroy*": "ask",
      "terraform apply*": "ask",
      "tofu apply*": "ask",
      "kubectl delete *": "ask",
      "kubectl drain *": "ask",
      "kubectl cordon *": "ask",
      "aws * delete*": "ask",
      "aws * terminate*": "ask",
      "docker system prune*": "ask",
      "docker volume prune*": "ask",
      "helm uninstall *": "ask",
      "helm rollback *": "ask",
    },
    "edit": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "webfetch": "allow",
    "external_directory": "ask",
    "doom_loop": "ask",
  },

  // -- Agents --
  "agent": {
    "build": {
      "description": "Implement changes",
      "mode": "primary",
      "prompt": "Senior DevOps/Platform engineer. Follow existing conventions, prefer minimal targeted changes, validate syntax before finishing.",
    },
    "plan": {
      "description": "Plan and review changes",
      "mode": "primary",
      "temperature": 0.1,
      "prompt": "Senior infrastructure architect. Consider blast radius, security, cost, idempotency, and drift risk. Plan only — do not make changes.",
    },
    "security": {
      "description": "Reviews infrastructure and config for security issues",
      "mode": "subagent",
      "color": "#ff6b6b",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "git diff*": "allow",
          "git log*": "allow",
          "grep *": "allow",
          "trivy *": "allow",
          "checkov *": "allow",
          "tfsec *": "allow",
        },
      },
      "prompt": "Cloud security engineer. Review infrastructure code for vulnerabilities and misconfigurations. Provide specific remediation steps. Do NOT modify files — report only.",
    },
    "cost": {
      "description": "Analyzes infrastructure for cost optimization opportunities",
      "mode": "subagent",
      "color": "#f0b429",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": { "*": "deny" },
      },
      "prompt": "Cloud cost optimization engineer. Analyze IaC for cost inefficiencies and over-provisioning. Provide actionable recommendations with estimated savings. Do NOT modify files.",
    },
  },

  // -- Commands --
  "command": {
    "test": {
      "description": "Run project tests and fix failures",
      "template": "Identify the test framework, run the tests, and report any failures with suggested fixes.",
    },
    "review": {
      "description": "Code review of recent changes",
      "template": "Run `git diff` and `git diff --cached`. Review for correctness, edge cases, security, performance, and readability.",
      "agent": "plan",
    },
    "commit": {
      "description": "Smart commit with conventional message",
      "template": "Review all staged and unstaged changes, draft a conventional commit message (type(scope): description), ask me to confirm, then commit.",
    },
    "fix": {
      "description": "Diagnose and fix an error",
      "template": "Analyze the error in: $ARGUMENTS. Find the root cause, explain it, and implement a fix.",
    },
    "refactor": {
      "description": "Refactor specified code",
      "template": "Refactor $ARGUMENTS. Improve readability and reduce complexity while preserving behavior.",
    },
    "explain": {
      "description": "Explain code in detail",
      "template": "Explain $ARGUMENTS: purpose, how it works, key patterns, and notable design decisions.",
      "agent": "plan",
    },
    "tf-plan": {
      "description": "Validate and explain Terraform plan",
      "template": "Run `terraform validate`, explain what `terraform plan` would change, highlight destroys/replacements, and flag security or cost concerns.",
    },
    "tf-docs": {
      "description": "Generate Terraform module docs",
      "template": "Generate or update README.md for the Terraform module in $ARGUMENTS with: description, inputs table, outputs table, and usage example.",
    },
    "docker-review": {
      "description": "Review Dockerfile for best practices",
      "template": "Review the Dockerfile in $ARGUMENTS for: multi-stage builds, layer caching, non-root user, minimal base image, secret handling, and .dockerignore coverage.",
    },
    "cicd-review": {
      "description": "Review CI/CD pipeline config",
      "template": "Review the CI/CD config in $ARGUMENTS for: secrets exposure, pinned action versions, caching, parallelism, and correctness.",
    },
    "k8s-review": {
      "description": "Review Kubernetes manifests",
      "template": "Review Kubernetes manifests in $ARGUMENTS for: resource limits, probes, security contexts, PDBs, HPAs, and RBAC.",
    },
    "shell-review": {
      "description": "Review and lint a shell script",
      "template": "Review $ARGUMENTS for: set -euo pipefail, quoting, error handling, security risks, and readability. Run shellcheck if available.",
    },
    "sec-scan": {
      "description": "Security scan of infra code",
      "template": "Security review of this project's infrastructure code. Prioritize findings by severity.",
      "agent": "security",
    },
    "runbook": {
      "description": "Generate an operational runbook",
      "template": "Create a runbook for $ARGUMENTS: overview, prerequisites, step-by-step instructions, expected outcomes, rollback procedure, and troubleshooting.",
    },
    "incident": {
      "description": "Incident response checklist",
      "template": "Incident involving: $ARGUMENTS. Provide immediate mitigation steps, diagnostic commands, and a structured response checklist.",
      "agent": "plan",
    },
  },

  // -- Instructions --
  "instructions": ["AGENTS.md"],

  // -- MCP Servers --
  "mcp": {
    // Live docs for Terraform providers, Kubernetes API, Helm, etc.
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
  },

  // -- Plugins --
  "plugin": ["@franlol/opencode-md-table-formatter@latest"],
}
